---
const { title, description, accentButton, note } = Astro.props as {
  title: string;
  description: string;
  accentButton: {
    label: string;
    href: string;
  };
  note?: string;
};
---
<section
  class="mt-20 relative overflow-hidden rounded-3xl bg-linear-to-br from-primary-950 via-primary-900 to-accent-900 p-8 md:p-12"
>
  <div
    class="pointer-events-none absolute -top-16 -right-10 h-40 w-40 rounded-full bg-accent-400/20 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -bottom-16 -left-10 h-40 w-40 rounded-full bg-primary-400/20 blur-3xl"
  >
  </div>

  <div class="relative max-w-2xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
      {title}
    </h2>

    <p class="text-primary-100 mb-6">
      {description}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={accentButton.href || "https://wa.me/5493435263931"}
        target="_blank"
        class="inline-flex items-center justify-center gap-2 rounded-xl bg-accent-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-accent-400"
      >
        {accentButton.label}
      </a>

      
    </div>

    <p class="mt-6 text-xs text-primary-200">
      {note}
    </p>
  </div>
</section>
