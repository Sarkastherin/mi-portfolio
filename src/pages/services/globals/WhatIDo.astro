---
import Image from "astro/components/Image.astro";
import type { ImageMetadata } from "astro";
interface WhatIDo {
  title: string;
  description: string;
  enum: string[];
  icon: string;
  note: string;
  img: { metaData: ImageMetadata; loading: "eager" | "lazy" };
}
const { whatIDo } = Astro.props as { whatIDo: WhatIDo[] };

---
<section class="mt-10">
      <h2
        class="text-xl md:text-2xl lg:text-3xl font-bold mb-10 text-primary-300"
      >
        ¿Qué puedo hacer por ti?"
      </h2>
      <div class="space-y-12">
        {
          whatIDo.map((item) => (
            <div class="border border-primary-800 bg-primary-900/30 rounded-2xl p-6 shadow-lg flex lg:flex-row flex-col items-center gap-6">
              <div class="flex-1">
                <div class="text-4xl mb-4">{item.icon}</div>
                <h3 class="text-xl text-primary-300 font-bold mb-2">
                  {item.title}
                </h3>
                <p class="text-gray-300 mb-4">{item.description}</p>
                <ul class="list-disc list-inside text-gray-400 space-y-1">
                  {item.enum.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
                <p class="mt-4 text-sm italic text-primary-300">{item.note}</p>
              </div>
              <div class="flex-1 rounded-xl overflow-hidden lg:ms-6 max-w-lg">
                <Image
                  src={item.img.metaData}
                  alt={item.title}
                  class={"w-full max-h-70 align-middle object-cover rounded-xl"}
                  loading={item.img.loading}
                />
              </div>
            </div>
          ))
        }
      </div>
    </section>